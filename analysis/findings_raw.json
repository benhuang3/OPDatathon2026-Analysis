  {
    "id": "H16",
    "title": "BERTopic on ai_opentext",
    "method": "BERTopic + paraphrase-multilingual-MiniLM-L12-v2",
    "n": 606,
    "n_topics": 3,
    "top_topics": {
      "Topic": {
        "0": -1,
        "1": 0,
        "2": 1
      },
      "Count": {
        "0": 102,
        "1": 428,
        "2": 76
      },
      "Name": {
        "0": "-1_to_the_and_it",
        "1": "0_to_and_ai_the",
        "2": "1_not_enough_no_know"
      },
      "Representation": {
        "0": [
          "to",
          "the",
          "and",
          "it",
          "ai",
          "that",
          "of",
          "in",
          "we",
          "for"
        ],
        "1": [
          "to",
          "and",
          "ai",
          "the",
          "of",
          "that",
          "it",
